generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  FLAGGED
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  name_en   String
  name_ar   String?
  name_fr   String?
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         String     @id @default(cuid())
  name       String     @unique  
  name_en    String
  name_ar    String?
  name_fr    String?
  slug       String?     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  properties Property[]
}

model Plan {
  id            String   @id
  title         String
  title_ar      String?
  title_fr      String?
  description   String
  description_ar String?
  description_fr String?
  price         Int
  listings      Int?     // null for unlimited
  featured      Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  phone        String?
  city         String?
  bio          String?
  planId       String     @default("free")
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  plan       Plan       @relation(fields: [planId], references: [id])
  properties Property[]
  favorites  Favorite[]
}

model Property {
  id          String   @id @default(cuid())
  title       String
  description String?
  city        String
  neighborhood String?
  area        Int?
  rooms       Int
  bathrooms   Int?
  price       Int
  categoryId  String
  featured    Boolean  @default(false)
  priceType   String   @default("MONTHLY") // "MONTHLY" or "DAILY"
  imageUrl    String?
  vedioUrl    String?
  sellerId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [name], onDelete: Restrict)
  seller   User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  media    Media[]
  favorites Favorite[]

  @@index([categoryId])
  @@index([city])
  @@index([neighborhood])
  @@index([featured])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Media {
  id          String   @id @default(cuid())
  url         String
  publicId    String
  type        String   @default("image") // "image" or "video"
  propertyId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}
